{
	"name": "conditionwithCross",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_matrimony",
						"type": "DatasetReference"
					},
					"name": "matrimony"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_target",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "females"
				},
				{
					"name": "select1"
				},
				{
					"name": "select2"
				},
				{
					"name": "join1"
				},
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          appid as string,",
				"          name as string,",
				"          gend as string,",
				"          age as integer,",
				"          city as string,",
				"          income as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> matrimony",
				"matrimony split(gend == \"m\",",
				"     disjoint: false) ~> females@(males, females)",
				"females@males select(mapColumn(",
				"          name,",
				"          gend,",
				"          age,",
				"          income",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"females@females select(mapColumn(",
				"          name,",
				"          gend,",
				"          age,",
				"          income",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select1, select2 join((select1@age > select2@age) && (select1@income > select2@income),",
				"     joinType:'cross',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 derive(agegap = select1@age - select2@age) ~> derivedColumn1",
				"derivedColumn1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['matrimonyfiles'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}