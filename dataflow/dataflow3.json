{
	"name": "dataflow3",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_customer9",
						"type": "DatasetReference"
					},
					"name": "emp1"
				},
				{
					"dataset": {
						"referenceName": "ds_emp",
						"type": "DatasetReference"
					},
					"name": "emp2"
				},
				{
					"dataset": {
						"referenceName": "ds_emp9",
						"type": "DatasetReference"
					},
					"name": "emp3"
				}
			],
			"sinks": [],
			"transformations": [
				{
					"name": "derivedColumn1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as string,",
				"          fname as string,",
				"          lname as string,",
				"          country as string,",
				"          sal as string,",
				"          dno as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> emp1",
				"source(output(",
				"          id as string,",
				"          fname as string,",
				"          lname as string,",
				"          country as string,",
				"          sal as string,",
				"          dno as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> emp2",
				"source(output(",
				"          id as string,",
				"          { fname} as string,",
				"          { country} as string,",
				"          { sal} as string,",
				"          { gen} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> emp3",
				"emp3 derive(fname = \"Unknown\") ~> derivedColumn1"
			]
		}
	}
}