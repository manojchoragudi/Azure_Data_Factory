{
	"name": "eliminate_dupes",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_newtrans",
						"type": "DatasetReference"
					},
					"name": "dupes"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_backups",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          {id,name,sal,gend,dno,city} as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> dupes",
				"dupes aggregate(groupBy({id,name,sal,gend,dno,city}),",
				"     cnt = count()) ~> aggregate1",
				"aggregate1 select(mapColumn(",
				"          {id,name,sal,gend,dno,city}",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['dupes'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}