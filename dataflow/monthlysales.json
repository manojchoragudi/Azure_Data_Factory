{
	"name": "monthlysales",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_sales_repo",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_backups",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "aggregate1"
				},
				{
					"name": "current"
				},
				{
					"name": "previous"
				},
				{
					"name": "previousmon2"
				},
				{
					"name": "join1"
				},
				{
					"name": "select2"
				},
				{
					"name": "derivedColumn2"
				}
			],
			"scriptLines": [
				"source(output(",
				"          Column_1 as string,",
				"          Column_2 as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 select(mapColumn(",
				"          dt = Column_1,",
				"          amount = Column_2",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"select1 derive(mon = toInteger(substring(dt,5, 2))) ~> derivedColumn1",
				"derivedColumn1 aggregate(groupBy(mon),",
				"     tot = sum(amount)) ~> aggregate1",
				"aggregate1 select(mapColumn(",
				"          cmon = mon,",
				"          ctot = tot",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> current",
				"aggregate1 select(mapColumn(",
				"          pmon = mon,",
				"          ptot = tot",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> previous",
				"previous derive(temp_mont = pmon +1) ~> previousmon2",
				"current, previousmon2 join(cmon > pmon,",
				"     joinType:'cross',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> join1",
				"join1 select(mapColumn(",
				"          cmon,",
				"          ctot,",
				"          pmon,",
				"          ptot",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"select2 derive(growthrate = 100*(cmon-pmon/pmon),",
				"          growthstatus = case(cmon>pmon ,\"increased\", cmon<pmon, \"decreased\", \"nochange\")) ~> derivedColumn2",
				"derivedColumn2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['monthlysales'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}