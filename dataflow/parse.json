{
	"name": "parse",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_info",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_backups",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "parse1"
				},
				{
					"name": "parse2"
				},
				{
					"name": "parse3"
				}
			],
			"scriptLines": [
				"source(output(",
				"          id as short,",
				"          name as string,",
				"          qual as string,",
				"          address as string,",
				"          university as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"source1 parse(Q = qual ? (q1 as string,",
				"          q2 as string,",
				"          q3 as string),",
				"     format: 'delimited',",
				"     columnNamesAsHeader: false,",
				"     columnDelimiter: '|',",
				"     nullValue: '') ~> parse1",
				"parse1 parse(contact = address ? (rec as (city as string,",
				"          country as string)),",
				"     format: 'xml',",
				"     namespaces: true) ~> parse2",
				"parse2 parse(edu = university ? (graduate as string,",
				"          postGraduate as string),",
				"     format: 'json',",
				"     documentForm: 'documentPerLine') ~> parse3",
				"parse3 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     partitionFileNames:['parsedatattata'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}