{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "practicestudio310"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/Practicereport')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_sales",
								"type": "DatasetReference"
							},
							"name": "source1"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_backups",
								"type": "DatasetReference"
							},
							"name": "sink1"
						},
						{
							"dataset": {
								"referenceName": "ds_backups",
								"type": "DatasetReference"
							},
							"name": "sink2"
						}
					],
					"transformations": [
						{
							"name": "derivedColumn1"
						},
						{
							"name": "monthlysale1"
						},
						{
							"name": "monthlysales2"
						},
						{
							"name": "join1"
						},
						{
							"name": "select1"
						},
						{
							"name": "derivedColumn2"
						},
						{
							"name": "derivedColumn3"
						},
						{
							"name": "qprice1"
						},
						{
							"name": "qprice2"
						},
						{
							"name": "join2"
						},
						{
							"name": "derivedColumn4"
						},
						{
							"name": "select2"
						},
						{
							"name": "sort1"
						},
						{
							"name": "sort2"
						}
					],
					"scriptLines": [
						"source(output(",
						"          dos as string,",
						"          Price as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> source1",
						"source1 derive(month = toInteger(substring(dos, 5, 2))) ~> derivedColumn1",
						"derivedColumn1 aggregate(groupBy(month),",
						"     price = sum(Price)) ~> monthlysale1",
						"derivedColumn1 aggregate(groupBy(month),",
						"     Price = sum(Price)) ~> monthlysales2",
						"monthlysales2, monthlysale1 join(monthlysales2@month - monthlysale1@month ==1,",
						"     joinType:'cross',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     broadcast: 'auto')~> join1",
						"join1 select(mapColumn(",
						"          cm = monthlysales2@month,",
						"          cmtot = monthlysales2@Price,",
						"          pm = monthlysale1@month,",
						"          pmtot = monthlysale1@price",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select1",
						"select1 derive(grate = ((cmtot-pmtot)/pmtot) * 100,",
						"          gstatus = iif(cmtot > pmtot, \"Increased\",\r",
						"   iif(cmtot == pmtot ,\"equal\", \"decreased\"))) ~> derivedColumn2",
						"monthlysale1 derive(q = case(month < 4, 1,\r",
						"    month <7, 2,\r",
						"    month < 10, 3, 4)) ~> derivedColumn3",
						"derivedColumn3 aggregate(groupBy(q),",
						"     price = sum(price)) ~> qprice1",
						"derivedColumn3 aggregate(groupBy(q),",
						"     price = sum(price)) ~> qprice2",
						"qprice2, qprice1 join(qprice2@q - qprice1@q ==1,",
						"     joinType:'cross',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     broadcast: 'auto')~> join2",
						"select2 derive(qgrate = ((ctotal-ptotal) / ptotal) *100,",
						"          qstatus = iif(ctotal<ptotal, \"increased\",\r",
						"  iif(ctotal == ptotal, \"equal\", \"decreased\"))) ~> derivedColumn4",
						"join2 select(mapColumn(",
						"          qcs = qprice2@q,",
						"          ctotal = qprice2@price,",
						"          qps = qprice1@q,",
						"          ptotal = qprice1@price",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select2",
						"derivedColumn2 sort(asc(cm, true),",
						"     asc(pm, true)) ~> sort1",
						"derivedColumn4 sort(desc(qcs, true)) ~> sort2",
						"sort2 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['quaterlySalesReport'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1",
						"sort1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['monthlySalesReport'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink2"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/commonRecords')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_demo1",
								"type": "DatasetReference"
							},
							"name": "demo1"
						},
						{
							"dataset": {
								"referenceName": "ds_demo2",
								"type": "DatasetReference"
							},
							"name": "demo2"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_backups",
								"type": "DatasetReference"
							},
							"name": "sink1"
						},
						{
							"dataset": {
								"referenceName": "ds_backups",
								"type": "DatasetReference"
							},
							"name": "sink2"
						},
						{
							"dataset": {
								"referenceName": "ds_backups",
								"type": "DatasetReference"
							},
							"name": "sink3"
						},
						{
							"dataset": {
								"referenceName": "ds_backups",
								"type": "DatasetReference"
							},
							"name": "sink4"
						}
					],
					"transformations": [
						{
							"name": "common"
						},
						{
							"name": "onlydemo1"
						},
						{
							"name": "onlydemo2"
						},
						{
							"name": "union1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          id as string,",
						"          name as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> demo1",
						"source(output(",
						"          id as string,",
						"          name as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> demo2",
						"demo1, demo2 exists(demo1@id == demo2@id,",
						"     negate:false,",
						"     broadcast: 'auto')~> common",
						"demo1, demo2 exists(demo1@id == demo2@id,",
						"     negate:true,",
						"     broadcast: 'auto')~> onlydemo1",
						"demo2, demo1 exists(demo2@id == demo1@id,",
						"     negate:true,",
						"     broadcast: 'auto')~> onlydemo2",
						"onlydemo1, onlydemo2 union(byName: true)~> union1",
						"union1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['irregular'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1",
						"onlydemo1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['onlydemo1'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink2",
						"common sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['common'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink3",
						"onlydemo2 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['onlydemo2'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink4"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/conditionwithCross')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "ds_matrimony",
								"type": "DatasetReference"
							},
							"name": "matrimony"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "ds_target",
								"type": "DatasetReference"
							},
							"name": "sink1"
						}
					],
					"transformations": [
						{
							"name": "females"
						},
						{
							"name": "select1"
						},
						{
							"name": "select2"
						},
						{
							"name": "join1"
						},
						{
							"name": "derivedColumn1"
						}
					],
					"scriptLines": [
						"source(output(",
						"          appid as string,",
						"          name as string,",
						"          gend as string,",
						"          age as integer,",
						"          city as string,",
						"          income as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false) ~> matrimony",
						"matrimony split(gend == \"m\",",
						"     disjoint: false) ~> females@(males, females)",
						"females@males select(mapColumn(",
						"          name,",
						"          gend,",
						"          age,",
						"          income",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select1",
						"females@females select(mapColumn(",
						"          name,",
						"          gend,",
						"          age,",
						"          income",
						"     ),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> select2",
						"select1, select2 join((select1@age > select2@age) && (select1@income > select2@income),",
						"     joinType:'cross',",
						"     matchType:'exact',",
						"     ignoreSpaces: false,",
						"     broadcast: 'auto')~> join1",
						"join1 derive(agegap = select1@age - select2@age) ~> derivedColumn1",
						"derivedColumn1 sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     partitionFileNames:['matrimonyfiles'],",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     partitionBy('hash', 1)) ~> sink1"
					]
				}
			},
			"dependsOn": []
		},
